// Windows version resource for quaero.exe (issue #192).
// Generated from this template by CMake configure_file(@ONLY); the version comes
// from the top-level VERSION file via project() — do not hardcode a version here.
// ASCII only on purpose: keeps the resource portable across the MSVC rc compiler
// and the MinGW windres toolchain regardless of the host codepage.
#include <winver.h>

// Application icon (issue #190). Resource id 1 = the lowest id, so Windows uses
// it as the executable's default icon in Explorer, the taskbar and the webview
// window. Path is injected by CMake (absolute, forward slashes) from
// assets/icons/quaero.ico.
1 ICON "@QUAERO_ICON_PATH@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Daniel Nunez Lopez"
            VALUE "FileDescription", "Quaero - Modern, lightweight, multi-engine database client"
            VALUE "FileVersion", "@QUAERO_VERSION@"
            VALUE "InternalName", "quaero"
            VALUE "LegalCopyright", "Copyright (C) 2026 Daniel Nunez Lopez. GPL-3.0-or-later."
            VALUE "OriginalFilename", "quaero.exe"
            VALUE "ProductName", "Quaero"
            VALUE "ProductVersion", "@QUAERO_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
